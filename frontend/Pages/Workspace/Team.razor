@page "/workspace/team"
@attribute [Authorize(Roles = "Team Lead")]
@layout NexusShellLayout

<PageTitle>Team — Nexus</PageTitle>

<div class="nx-page">
    <div class="nx-team-head">
        <div>
            <h2 class="nx-page-title nx-m0">Team directory</h2>
            <p class="nx-muted" style="display:none;"></p>
        </div>
        <button type="button" class="nx-btn-primary nx-btn-sm">+ Invite member</button>
    </div>
    <div class="nx-team-stats" style="display:none;"></div>

    <div class="nx-member-grid" style="display:none;"></div>

    <div class="nx-panel nx-mt" style="display:none;"></div>
</div>
